#include <stdio.h>
#include <string.h>
#include <ctype.h>

int isValidRegex(char exp[]) {
    int i, len = strlen(exp);
    int balance = 0;

    // First character should not be operator
    if (exp[0] == '*' || exp[0] == '+' || exp[0] == '|')
        return 0;

    for (i = 0; i < len; i++) {
        char ch = exp[i];

        // Check valid characters
        if (!isalnum(ch) && ch!='(' && ch!=')' && ch!='*' && ch!='+' && ch!='|') {
            return 0;
        }

        // Check parentheses balance
        if (ch == '(')
            balance++;
        else if (ch == ')')
            balance--;

        if (balance < 0)
            return 0;

        // Check consecutive operators
        if ((ch=='*' || ch=='+' || ch=='|') &&
            (exp[i+1]=='*' || exp[i+1]=='+' || exp[i+1]=='|')) {
            return 0;
        }
    }

    if (balance != 0)
        return 0;

    return 1;
}

int main() {
    char exp[100];

    printf("Enter a regular expression: ");
    scanf("%s", exp);

    if (isValidRegex(exp))
        printf("Valid Regular Expression\n");
    else
        printf("Invalid Regular Expression\n");

    return 0;
}
