#include <stdio.h>
#include <string.h>

int main() {
    char expr1[50], expr2[50];

    printf("Enter first expression:\n");
    scanf("%s", expr1);

    printf("Enter second expression:\n");
    scanf("%s", expr2);

    if (strcmp(expr1, expr2) == 0) {
        printf("Common subexpression detected\n");
        printf("Optimized: compute once and reuse\n");
    } else {
        printf("No optimization possible\n");
    }

    return 0;
}
